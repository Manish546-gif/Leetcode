        "problemId": "2341-maximum-number-of-pairs-in-array",
        "title": "Maximum Number Of Pairs In Array",
        "code": "class Solution {\npublic:\n    vector<int> numberOfPairs(vector<int>& nums) {\n        vector<int> arr(101, 0);\n\n        for (int i = 0; i < nums.size(); i++) {\n            arr[nums[i]]++;\n        }\n\n        int pairs = 0;\n        int rem = 0;\n\n        for (int i = 0; i < 101; i++) {\n            pairs += arr[i] / 2;   \n            rem += arr[i] % 2;    \n        }\n\n        return {pairs, rem};\n    }\n};\n",
